# App (Vite) — public keys only
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Optional: home page redirects to this creator handle
# VITE_DEFAULT_CREATOR_HANDLE=myhandle

# One-time migration: Google Sheets → Supabase (npm run migrate:sheet)
# GOOGLE_SHEET_ID=
# GOOGLE_SHEETS_API_KEY=
# GOOGLE_SHEET_RANGE=Sheet1!A:ZZ
# MIGRATION_CREATOR_ID=
# Never commit the service role key:
# SUPABASE_SERVICE_ROLE_KEY=
# MIGRATION_DRY_RUN=1
